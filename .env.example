# Server-only. Put real values in Vercel Environment Variables.
APP_SECRET=

# Lemon Squeezy checkout links. Public links can also live in config.js.
LEMON_SQUEEZY_INDIVIDUAL_URL=
LEMON_SQUEEZY_PACK5_URL=
LEMON_SQUEEZY_PACK20_URL=https://pruebapdf.lemonsqueezy.com/checkout/buy/b2601b5d-25da-4bf0-a750-80c1ef46b0e8

# Lemon Squeezy private settings.
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Product/variant IDs. Pack 20 is enough to start real sales.
LEMON_SQUEEZY_INDIVIDUAL_PRODUCT_ID=
LEMON_SQUEEZY_INDIVIDUAL_VARIANT_ID=
LEMON_SQUEEZY_PACK5_PRODUCT_ID=
LEMON_SQUEEZY_PACK5_VARIANT_ID=
LEMON_SQUEEZY_PACK20_PRODUCT_ID=1156508
LEMON_SQUEEZY_PACK20_VARIANT_ID=

# Vercel KV / Upstash Redis REST credentials.
KV_REST_API_URL=
KV_REST_API_TOKEN=
